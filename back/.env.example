PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# Railway can provide DATABASE_URL from the PostgreSQL service.
DATABASE_URL=

# Local PostgreSQL fallback if DATABASE_URL is not set.
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=
DB_NAME=proyecto_m4_front
DB_SYNCHRONIZE=true

JWT_SECRET=
JWT_EXPIRES_IN=7d

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/users/google/callback
